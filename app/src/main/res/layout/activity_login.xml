<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- App Logo -->

        <!-- Title -->
        <ImageView
            android:id="@+id/img_logo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="PizzaMania Logo"
            android:src="@drawable/ic_launcher_foreground" />

        <TextView
            android:id="@+id/txt_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to PizzaMania"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="4dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/txt_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hot, fresh and handcrafted pizzas"
            android:textSize="14sp"
            android:textColor="#777777"
            android:layout_marginBottom="32dp" />

        <!-- Email Input -->
        <EditText
            android:id="@+id/edt_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your Email"
            android:inputType="textEmailAddress"
            android:background="@drawable/edittext_bg"
            android:padding="14dp"

            android:drawablePadding="10dp"
            android:layout_marginBottom="16dp" />
            <!--android:drawableLeft="@drawable/ic_emai"-->

        <!-- Password Input -->
        <EditText
            android:id="@+id/edt_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Create Password"
            android:inputType="textPassword"
            android:background="@drawable/edittext_bg"
            android:padding="14dp"

            android:drawablePadding="10dp"
            android:layout_marginBottom="8dp" />
        <!-- android:drawableLeft="@drawable/ic_lock" -->
        <!-- Forgot Password -->
        <TextView
            android:id="@+id/txt_forgot_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password?"
            android:textSize="14sp"
            android:textColor="#FF5722"
            android:layout_gravity="end"
            android:layout_marginBottom="24dp" />

        <!-- Login Button -->
        <Button
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Login"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#FF5722"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"
            android:padding="14dp" />

        <!-- Or continue with -->
        <TextView
            android:id="@+id/txt_or_continue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Or continue with"
            android:textSize="14sp"
            android:textColor="#777777"
            android:layout_marginBottom="16dp" />

        <!-- Social Buttons Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3">

            <ImageButton
                android:id="@+id/btn_google"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"

                android:background="@android:color/transparent"
                android:contentDescription="Login with Google" />
                <!--android:src="@drawable/ic_google"-->

            <ImageButton
                android:id="@+id/btn_apple"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"

                android:background="@android:color/transparent"
                android:contentDescription="Login with Apple" />
                <!--android:src="@drawable/ic_apple"-->

            <ImageButton
                android:id="@+id/btn_facebook"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"

                android:background="@android:color/transparent"
                android:contentDescription="Login with Facebook" />
                <!--android:src="@drawable/ic_facebook"-->
        </LinearLayout>

        <!-- Sign Up Link -->
        <TextView
            android:id="@+id/txt_signup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don’t have an account? Sign up"
            android:textSize="14sp"
            android:textColor="#FF5722"
            android:layout_marginTop="32dp"
            android:layout_gravity="center" />
    </LinearLayout>
</ScrollView>
